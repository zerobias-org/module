{
  "affected": {
    "defaultBase": "main"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": [
          "build",
          "docs",
          "generate",
          "lint",
          "test"
        ],
        "parallel": 4
      }
    }
  },
  "targetDefaults": {
    "clean": {},
    "lint": {
      "dependsOn": [
        "^generate"
      ]
    },
    "generate": {
      "dependsOn": [
        "^nx:build"
      ]
    },
    "nx:build": {
      "dependsOn": [
        "^nx:build",
        "generate"
      ]
    }
  }
}
