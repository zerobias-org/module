{
  "name": "@zerobias-org/module",
  "version": "1.0.0",
  "private": true,
  "description": "Zerobias module artifacts",
  "main": "main.js",
  "workspaces": [
    "package/**",
    "utils/**"
  ],
  "scripts": {
    "build": "nx affected -t build",
    "build:full": "nx run-many -t build",
    "validate": "nx run-many -t validate",
    "clean": "nx affected -t clean && nx reset && find . -name tsconfig.tsbuildinfo -delete || echo \"\"",
    "clean:full": "nx run-many -t clean && nx reset && find . -name tsconfig.tsbuildinfo -delete || echo \"\"",
    "docs": "nx run-many -t docs",
    "generate:bom": "nx run-many -t generate:bom",
    "lerna:publish": "lerna publish --conventional-commits",
    "lerna:publish-from-package": "lerna publish from-package",
    "lerna:dry-run": "lerna version --no-git-tag-version --no-push --conventional-commits",
    "lerna:version": "lerna version --no-git-tag-version --no-push --conventional-commits --yes",
    "lerna:version:hotfix": "lerna version --no-git-tag-version --no-push --conventional-prerelease --preid hotfix --conventional-commits --yes",
    "lint": "nx run-many -t lint",
    "lint:full": "nx affected -t lint",
    "lint:fix": "nx run-many -t lint:src:fix",
    "reset": "npm run clean:full && npm install && npm run build:full",
    "test": "nx affected -t test",
    "test:full": "nx run-many -t test",
    "nx:publish": "lerna list --since HEAD~1 --json | jq -r '.[].location' | xargs -I {} bash -c 'cd {} && publish'",
    "prepublish-init": "prepublish-init"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerobias-org/module.git"
  },
  "author": "team@zerobias.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zerobias-org/module/issues"
  },
  "homepage": "https://github.com/zerobias-org/module#readme",
  "overrides": {
    "@zerobias-org/types-core-js": "^1.2.9",
    "@rollup/plugin-commonjs": "^28.0.0",
    "diff": "^8.0.3",
    "tar": "^7.5.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "lerna": "^9.0.3",
    "nx": "^20.5.0"
  }
}
