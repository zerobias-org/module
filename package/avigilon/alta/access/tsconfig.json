{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitAny": false,
    "target": "ES2022",
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "lib": ["ES2022"],
    "outDir": "dist",
    "esModuleInterop": true,
    "useUnknownInCatchVariables": false
  },
  "include": ["src/**/*", "test/**/*", "generated/**/*"],
  "exclude": ["dist", "node_modules", "hub-sdk"]
}
