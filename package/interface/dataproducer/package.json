{
  "name": "@zerobias-org/module-interface-dataproducer",
  "version": "2.1.4",
  "description": "Dynamic Data Producer Interface",
  "moduleId": "a2b032b3-eb87-4cb8-8916-8fbbd4c3fcef",
  "type": "module",
  "interface": true,
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./api": {
      "types": "./dist/generated/api/index.d.ts",
      "import": "./dist/generated/api/index.js"
    },
    "./model": {
      "types": "./dist/generated/model/index.d.ts",
      "import": "./dist/generated/model/index.js"
    }
  },
  "author": "team@zerobias.com",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobias-org/module",
    "directory": "package/interface/dataproducer"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "clean": "rm -rf build/ dist/ generated/ hub-sdk/generated hub-sdk/tsconfig.json hub-sdk/dist module-interface-dataproducer.yml full.yml"
  },
  "files": [
    "dist",
    "generated/api/manifest.json",
    "api.yml",
    "connectionProfile.yml"
  ],
  "zerobias": {
    "package": "zerobias.interface.dataproducer.module",
    "dataloader-version": "1.0.0",
    "import-artifact": "module"
  },
  "overrides": {
    "diff": ">=8.0.3",
    "serialize-javascript": ">=7.0.3"
  },
  "dependencies": {
    "@zerobias-org/product-zerobias-zerobias": "latest",
    "@zerobias-org/util-connector": "^1.0.40",
    "axios": "1.15.0"
  },
  "peerDependencies": {
    "@zerobias-org/types-core": "^1.0.22",
    "@zerobias-org/types-core-js": "^1.2.19"
  },
  "devDependencies": {
    "@redocly/cli": "2.28.1",
    "@types/mocha": "10.0.10",
    "@types/node": "22.19.17",
    "@zerobias-org/eslint-config": "^1.0.38",
    "@zerobias-org/module-test-client": "^1.0.5",
    "@zerobias-org/util-api-client-base": "^1.0.44",
    "@zerobias-org/util-codegen": "^2.0.49",
    "mocha": "11.7.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
